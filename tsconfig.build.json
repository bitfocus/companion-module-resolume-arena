{
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**", "src/**/*spec.ts", "src/__tests__/**", "src/__mocks__/**", "test/**"],
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"module": "Node16",
		"moduleResolution": "Node16",
		"target": "es2022",
		"noImplicitAny": true,
		"sourceMap": true,
		"declaration": false,
		"importHelpers": false,
		"listFiles": false,
		"traceResolution": false,
		"pretty": true,
		"lib": ["es2022"],
		"strict": true,
		"alwaysStrict": false,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": false,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"compileOnSave": false
}
